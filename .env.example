# OpenAI API key. Required when LLM_PROVIDER=openai_api, and also required for image generation.
OPENAI_API_KEY=your_api_key_here

# Slide plan generation provider: openai_api or codex_cli.
LLM_PROVIDER=openai_api

# Model used for slide plan generation.
OPENAI_MODEL=gpt-5.4

# Enable OpenAI image generation for slide image placeholders.
OPENAI_ENABLE_IMAGE_GENERATION=false

# OpenAI image generation model used when OPENAI_ENABLE_IMAGE_GENERATION=true.
# OPENAI_IMAGE_MODEL=gpt-image-1

# Optional custom OpenAI-compatible API endpoint.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Timeout in seconds for OpenAI API calls.
OPENAI_TIMEOUT_SECONDS=300

# Codex CLI executable command. Usually keep this as codex.
# CODEX_CLI_COMMAND=codex

# Timeout in seconds for Codex CLI calls. If omitted, OPENAI_TIMEOUT_SECONDS is used.
# CODEX_CLI_TIMEOUT_SECONDS=300

# Continue generating remaining sessions when one session fails.
CONTINUE_ON_SESSION_ERROR=true
